# Server
SERVER_PORT=8080

# Database
DATABASE_URL=postgres://engram:engram@localhost:5432/engram?sslmode=disable
# Connection pool sizing. The pgx default (4) starves a busy server; these let
# you size to your Postgres without needing PgBouncer for small/mid deployments.
# DB_MAX_CONNS=25
# DB_MIN_CONNS=2
# DB_MAX_CONN_LIFETIME_SECS=3600           # recycle a connection after this long
# DB_MAX_CONN_IDLE_SECS=1800               # close a connection idle this long

# Migrations
MIGRATIONS_PATH=migrations

# LLM Provider (openai, anthropic, gemini, cerebras, mock)
LLM_PROVIDER=openai
EMBEDDING_PROVIDER=openai

# API Keys (store in .env.secret or .env.development.local.secret)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=...
# CEREBRAS_API_KEY=...

# Bootstrap — set this to a strong random string before first run.
# POST /v1/setup (and the deprecated POST /v1/tenants) require
# X-Setup-Token: <value> to create a tenant + master key.
# Leave empty to disable both endpoints.
# ENGRAM_SETUP_TOKEN=change-me-before-deploy

# Rate Limiting
RATE_LIMIT_RPS=100
RATE_LIMIT_BURST=20
# Honor X-Real-IP/X-Forwarded-For for rate limiting ONLY when running behind a
# proxy that strips and re-sets them; from direct clients they are spoofable.
# TRUST_PROXY_HEADERS=true

# Console session cookie. Secure-by-default (cookie only sent over HTTPS). For
# local http://localhost development you MUST set COOKIE_SECURE=false, otherwise
# the browser will not send the session cookie and console login appears to fail.
# COOKIE_SECURE=false
# SESSION_TTL_HOURS=168                      # console session lifetime (default 7 days)
# Browser origins allowed to call the API cross-origin (comma-separated). The
# embedded console is same-origin and does not need to be listed.
# CORS_ALLOWED_ORIGINS=https://console.hakuya.ai

# Billing / managed cloud (Razorpay). Leave RAZORPAY_KEY_ID + RAZORPAY_KEY_SECRET
# unset for self-hosted/OSS: billing endpoints report "not configured" and plan
# quotas are NOT enforced (unmetered). Set both to turn on metering + quota
# enforcement. Use Razorpay test-mode keys (rzp_test_...) for development.
# RAZORPAY_KEY_ID=rzp_test_...
# RAZORPAY_KEY_SECRET=...
# RAZORPAY_WEBHOOK_SECRET=...                # set on the webhook in the Razorpay dashboard
# Razorpay Plan IDs for the self-serve plans (create them in the Razorpay dashboard):
# RAZORPAY_PLAN_DEVELOPER=plan_...           # Developer $29/mo
# RAZORPAY_PLAN_TEAM=plan_...                # Team $149/mo
# RAZORPAY_PLAN_GROWTH=plan_...              # Growth $499/mo
# APP_BASE_URL=https://console.hakuya.ai     # console base URL

# MCP server: usage instructions sent to the host in the `initialize` response.
# This is what makes connected agents auto-adopt Engram as memory (recall at the
# start of a conversation, remember durable facts) WITHOUT any system-prompt
# wiring on the host side. A strong default ships in the binary — only set this
# to override the wording, or set it empty to disable auto-adoption entirely.
# ENGRAM_MCP_INSTRUCTIONS=

# Logging
LOG_LEVEL=info
