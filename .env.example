# Server
SERVER_PORT=8080

# Database
DATABASE_URL=postgres://engram:engram@localhost:5432/engram?sslmode=disable

# Migrations
MIGRATIONS_PATH=migrations

# LLM Provider (openai, anthropic, gemini, cerebras, mock)
LLM_PROVIDER=openai
EMBEDDING_PROVIDER=openai

# API Keys (store in .env.secret or .env.development.local.secret)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=...
# CEREBRAS_API_KEY=...

# Bootstrap — set this to a strong random string before first run.
# POST /v1/setup (and the deprecated POST /v1/tenants) require
# X-Setup-Token: <value> to create a tenant + master key.
# Leave empty to disable both endpoints.
# ENGRAM_SETUP_TOKEN=change-me-before-deploy

# Rate Limiting
RATE_LIMIT_RPS=100
RATE_LIMIT_BURST=20
# Honor X-Real-IP/X-Forwarded-For for rate limiting ONLY when running behind a
# proxy that strips and re-sets them; from direct clients they are spoofable.
# TRUST_PROXY_HEADERS=true

# Billing / managed cloud (Stripe). Leave STRIPE_SECRET_KEY unset for
# self-hosted/OSS: billing endpoints report "not configured" and plan quotas
# are NOT enforced (unmetered). Set it to turn on metering + quota enforcement.
# Use Stripe test keys (sk_test_...) for development — test mode is free.
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...           # from `stripe listen` or the dashboard
# Stripe Price IDs for the self-serve plans (create them in the Stripe dashboard):
# STRIPE_PRICE_DEVELOPER=price_...          # Developer $29/mo
# STRIPE_PRICE_TEAM=price_...               # Team $149/mo
# STRIPE_PRICE_GROWTH=price_...             # Growth $499/mo
# APP_BASE_URL=https://console.engram.to    # used for checkout success/cancel + portal return URLs

# Logging
LOG_LEVEL=info
